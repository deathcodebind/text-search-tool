{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Text Search Tool",
  "version": "0.2.1",
  "identifier": "com.huyingjie.textsearchtool",
  "build": {
    "beforeBuildCommand": "cd ../ui && npm install && npm run build",
    "beforeDevCommand": "cd ../ui && npm install && npm run dev",
    "devUrl": "http://localhost:4173",
    "frontendDist": "../ui/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Text Search Tool v0.2.1",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
